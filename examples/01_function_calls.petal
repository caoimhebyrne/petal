// In the previous example, we declared a function `main`.
// You can declare any function and it can return any value.

// This function returns an i32, which is just the constant '69'.
func produce() -> i32 {
    return 69;
}

// The `main` function is the same as the previous example.
func main() -> i32 {
    // We can call other functions by their names, and if they return a value, we can use it.
    return produce();
}
