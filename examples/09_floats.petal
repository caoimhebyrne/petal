// Integers have been used in examples up to this point, but floats can also be used.
// When using external functions like `printf`, `f64` should almost exclusively be used, but
// `f32` is still available for certain operations.

// void printf(format: char*, ...);
extern func printf(&format: i8, value: f64);

func main() {
    f64 value = 3.14 / 6.69;
    printf("value = %f\n", value);
}
