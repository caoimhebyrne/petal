// Addition, multiplicaton, subtraction, and division are all examples of binary operations.
// Binary operations can be performed on values by using the `+`, `-`, `*`, and `/` operands.
func main() -> i32 {
    add: i32 =   5 + 5;  // 10
    sub: i32 = add - 2;  // 8
    mul: i32 = sub * 2;  // 16
    div: i32 = mul / 4;  // 4

    return div;
}
