import string;
import libc;

namespace io {

    // Prints a [StringView], followed by a new-line, to the standard output.
    public func println(string_view: StringView) {
        // FIXME: FD 1 on POSIX is `stdout`.
        stdout_fd: i32 = 1;
        newline: StringView = "\n";

        libc::write(filedes: stdout_fd, buf: string_view.data, nbyte: string_view.length);
        libc::write(filedes: stdout_fd, buf: newline.data,     nbyte: newline.length);
    }

}
