namespace io {

    // Prints a [string], followed by a new-line, to the standard output.
    public func println(string: str) {
        // FIXME: FD 1 on POSIX is `stdout`.
        stdout_fd: i32 = 1;
        newline_string: str = "\n";

        libc::write(filedes: stdout_fd, buf: string.data,    nbyte: string.length);
        libc::write(filedes: stdout_fd, buf: newline_string.data, nbyte: newline_string.length);
    }

}
